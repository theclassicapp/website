---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for th locale (entries with th/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('th/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('th/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'th/' + slug);

if (!entry) {
  return Astro.redirect('/th/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="th">
  <Content />
</HelpLayout>
