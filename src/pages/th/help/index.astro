---
import '@/styles/global.css';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { withBase } from '@/i18n';

const base = import.meta.env.BASE_URL;

const helpCategories = [
  {
    title: 'เริ่มต้นใช้งาน',
    description: 'เรียนรู้พื้นฐานของ Classic และเริ่มต้นได้อย่างรวดเร็ว',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    articles: [
      { slug: 'getting-started', title: 'คู่มือเริ่มใช้งานอย่างรวดเร็ว' },
      { slug: 'interface', title: 'ทำความเข้าใจอินเทอร์เฟซ' },
      { slug: 'first-note', title: 'สร้างโน้ตแรกของคุณ' },
    ],
  },
  {
    title: 'เอดิเตอร์และการเขียน',
    description: 'เชี่ยวชาญเอดิเตอร์อันทรงพลังและฟีเจอร์ทั้งหมด',
    icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
    articles: [
      { slug: 'markdown', title: 'เอกสารอ้างอิง Markdown' },
      { slug: 'slash-commands', title: 'Slash Commands' },
      { slug: 'diagrams', title: 'ไดอะแกรม Mermaid' },
      { slug: 'math', title: 'สมการคณิตศาสตร์' },
      { slug: 'code-blocks', title: 'บล็อกโค้ด' },
    ],
  },
  {
    title: 'การจัดระเบียบ',
    description: 'จัดระเบียบโน้ตของคุณด้วยแท็ก ซับโน้ต และแบ็กลิงก์',
    icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
    articles: [
      { slug: 'subnotes', title: 'ซับโน้ต' },
      { slug: 'tags', title: 'การทำงานกับแท็ก' },
      { slug: 'backlinks', title: 'แบ็กลิงก์' },
      { slug: 'daily-notes', title: 'โน้ตประจำวัน' },
      { slug: 'search', title: 'การค้นหา' },
    ],
  },
  {
    title: 'ประสิทธิภาพการทำงาน',
    description: 'เพิ่มประสิทธิภาพการทำงานด้วยชอร์ตคัตและระบบอัตโนมัติ',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    articles: [
      { slug: 'quick-capture', title: 'Quick Capture' },
      { slug: 'command-palette', title: 'Command Palette' },
      { slug: 'keyboard-shortcuts', title: 'คีย์ลัด' },
      { slug: 'system-tray', title: 'ถาดระบบ' },
    ],
  },
  {
    title: 'ข้อมูลและความเป็นส่วนตัว',
    description: 'เข้าใจวิธีที่ Classic จัดการข้อมูลของคุณ',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    articles: [
      { slug: 'local-first', title: 'สถาปัตยกรรม Local-First' },
      { slug: 'backup', title: 'สำรองและกู้คืนข้อมูล' },
      { slug: 'version-history', title: 'ประวัติเวอร์ชัน' },
      { slug: 'import-export', title: 'นำเข้าและส่งออก' },
    ],
  },
  {
    title: 'การปรับแต่ง',
    description: 'ปรับแต่ง Classic ให้เหมาะกับเวิร์กโฟลว์ของคุณ',
    icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
    articles: [
      { slug: 'themes', title: 'ธีมและรูปลักษณ์' },
      { slug: 'languages', title: 'การตั้งค่าภาษา' },
      { slug: 'settings', title: 'ภาพรวมการตั้งค่า' },
    ],
  },
];
---

<BaseLayout title="ศูนย์ช่วยเหลือ — Classic">
  <Header />
  <main>
    <section class="py-24 text-center">
      <div class="mx-auto max-w-6xl px-6">
        <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          ศูนย์ช่วยเหลือ
        </h1>
        <p class="mt-4 text-lg text-foreground-muted">
          ทุกสิ่งที่คุณต้องรู้เกี่ยวกับ Classic ค้นหาคู่มือ บทช่วยสอน และคำตอบสำหรับคำถามที่พบบ่อย
        </p>
      </div>
    </section>

    <section class="bg-surface-dim py-16">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {helpCategories.map((category) => (
            <div class="rounded-xl border border-border bg-surface p-6">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={category.icon} />
                </svg>
              </div>
              <h3 class="mt-4 text-lg font-semibold text-foreground">
                {category.title}
              </h3>
              <p class="mt-2 text-sm text-foreground-muted">
                {category.description}
              </p>
              <ul class="mt-4 space-y-2">
                {category.articles.map((article) => (
                  <li>
                    <a
                      href={withBase(base, `/th/help/${article.slug}`)}
                      class="flex items-center gap-2 text-sm text-primary hover:underline"
                    >
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      {article.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold text-foreground">บทความยอดนิยม</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <a href={withBase(base, '/th/help/getting-started')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">คู่มือเริ่มใช้งานอย่างรวดเร็ว</h3>
            <p class="mt-1 text-sm text-foreground-muted">เริ่มต้นกับ Classic ใน 5 นาที</p>
          </a>
          <a href={withBase(base, '/th/help/markdown')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">เอกสารอ้างอิง Markdown</h3>
            <p class="mt-1 text-sm text-foreground-muted">คู่มือฉบับสมบูรณ์สำหรับไวยากรณ์ Markdown</p>
          </a>
          <a href={withBase(base, '/th/help/keyboard-shortcuts')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">คีย์ลัด</h3>
            <p class="mt-1 text-sm text-foreground-muted">ทำงานได้เร็วขึ้นด้วยคีย์ลัด</p>
          </a>
          <a href={withBase(base, '/th/help/local-first')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">สถาปัตยกรรม Local-First</h3>
            <p class="mt-1 text-sm text-foreground-muted">Classic รักษาความเป็นส่วนตัวของข้อมูลคุณอย่างไร</p>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
