---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for he locale (entries with he/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('he/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('he/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'he/' + slug);

if (!entry) {
  return Astro.redirect('/he/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="he">
  <Content />
</HelpLayout>
