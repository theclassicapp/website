---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for vi locale (entries with vi/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('vi/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('vi/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'vi/' + slug);

if (!entry) {
  return Astro.redirect('/vi/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="vi">
  <Content />
</HelpLayout>
