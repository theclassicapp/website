---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for fr locale (entries with fr/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('fr/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('fr/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'fr/' + slug);

if (!entry) {
  return Astro.redirect('/fr/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="fr">
  <Content />
</HelpLayout>
