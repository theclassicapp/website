---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for pl locale (entries with pl/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('pl/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('pl/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'pl/' + slug);

if (!entry) {
  return Astro.redirect('/pl/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="pl">
  <Content />
</HelpLayout>
