---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  const localeEntries = helpEntries.filter(entry => entry.slug.startsWith('pl/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.slug.replace('pl/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.slug === `pl/${slug}`);

if (!entry) {
  return Astro.redirect('/pl/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="pl">
  <Content />
</HelpLayout>
