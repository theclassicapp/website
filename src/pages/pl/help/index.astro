---
import '@/styles/global.css';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { withBase } from '@/i18n';

const base = import.meta.env.BASE_URL;

const helpCategories = [
  {
    title: 'Pierwsze Kroki',
    description: 'Poznaj podstawy Classic i zacznij szybko.',
    articles: [
      { slug: 'getting-started', title: 'Przewodnik Szybki Start' },
      { slug: 'interface', title: 'Zrozumienie Interfejsu' },
      { slug: 'first-note', title: 'Tworzenie Pierwszej Notatki' },
    ],
  },
  {
    title: 'Edytor i Pisanie',
    description: 'Opanuj potężny edytor i wszystkie jego funkcje.',
    articles: [
      { slug: 'markdown', title: 'Referencja Markdown' },
      { slug: 'slash-commands', title: 'Polecenia Slash' },
      { slug: 'diagrams', title: 'Diagramy Mermaid' },
      { slug: 'math', title: 'Równania Matematyczne' },
      { slug: 'code-blocks', title: 'Bloki Kodu' },
    ],
  },
  {
    title: 'Organizacja',
    description: 'Organizuj notatki za pomocą tagów, podnotatek i backlinków.',
    articles: [
      { slug: 'subnotes', title: 'Podnotatki' },
      { slug: 'tags', title: 'Praca z Tagami' },
      { slug: 'backlinks', title: 'Backlinki' },
      { slug: 'daily-notes', title: 'Notatki Dzienne' },
      { slug: 'search', title: 'Wyszukiwanie' },
    ],
  },
  {
    title: 'Produktywność',
    description: 'Zwiększ produktywność dzięki skrótom i automatyzacji.',
    articles: [
      { slug: 'quick-capture', title: 'Szybkie Przechwytywanie' },
      { slug: 'command-palette', title: 'Paleta Poleceń' },
      { slug: 'keyboard-shortcuts', title: 'Skróty Klawiaturowe' },
      { slug: 'system-tray', title: 'Zasobnik Systemowy' },
    ],
  },
  {
    title: 'Dane i Prywatność',
    description: 'Zrozum, jak Classic obsługuje Twoje dane.',
    articles: [
      { slug: 'local-first', title: 'Architektura Local-First' },
      { slug: 'backup', title: 'Kopia Zapasowa i Przywracanie' },
      { slug: 'version-history', title: 'Historia Wersji' },
      { slug: 'import-export', title: 'Import i Eksport' },
    ],
  },
  {
    title: 'Dostosowanie',
    description: 'Dostosuj Classic do swojego przepływu pracy.',
    articles: [
      { slug: 'themes', title: 'Motywy i Wygląd' },
      { slug: 'languages', title: 'Ustawienia Językowe' },
      { slug: 'settings', title: 'Przegląd Ustawień' },
    ],
  },
];
---

<BaseLayout title="Centrum Pomocy — Classic">
  <Header />
  <main>
    <section class="py-24 text-center">
      <div class="mx-auto max-w-6xl px-6">
        <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Centrum Pomocy
        </h1>
        <p class="mt-4 text-lg text-foreground-muted">
          Wszystko, co musisz wiedzieć o Classic. Znajdź przewodniki, samouczki i odpowiedzi na często zadawane pytania.
        </p>
      </div>
    </section>

    <section class="bg-surface-dim py-16">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {helpCategories.map((category) => (
            <div class="rounded-xl border border-border bg-surface p-6">
              <h3 class="text-lg font-semibold text-foreground">
                {category.title}
              </h3>
              <p class="mt-2 text-sm text-foreground-muted">
                {category.description}
              </p>
              <ul class="mt-4 space-y-2">
                {category.articles.map((article) => (
                  <li>
                    <a
                      href={withBase(base, `/pl/help/${article.slug}`)}
                      class="flex items-center gap-2 text-sm text-primary hover:underline"
                    >
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      {article.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold text-foreground">Popularne Artykuły</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <a href={withBase(base, '/pl/help/getting-started')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Przewodnik Szybki Start</h3>
            <p class="mt-1 text-sm text-foreground-muted">Zacznij z Classic w 5 minut.</p>
          </a>
          <a href={withBase(base, '/pl/help/markdown')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Referencja Markdown</h3>
            <p class="mt-1 text-sm text-foreground-muted">Kompletny przewodnik po składni Markdown.</p>
          </a>
          <a href={withBase(base, '/pl/help/keyboard-shortcuts')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Skróty Klawiaturowe</h3>
            <p class="mt-1 text-sm text-foreground-muted">Pracuj szybciej ze skrótami klawiaturowymi.</p>
          </a>
          <a href={withBase(base, '/pl/help/local-first')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Architektura Local-First</h3>
            <p class="mt-1 text-sm text-foreground-muted">Jak Classic chroni prywatność Twoich danych.</p>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
