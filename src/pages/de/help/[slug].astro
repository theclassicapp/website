---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for de locale (entries with de/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('de/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('de/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'de/' + slug);

if (!entry) {
  return Astro.redirect('/de/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="de">
  <Content />
</HelpLayout>
