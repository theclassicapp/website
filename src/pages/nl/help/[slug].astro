---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for nl locale (entries with nl/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('nl/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('nl/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'nl/' + slug);

if (!entry) {
  return Astro.redirect('/nl/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="nl">
  <Content />
</HelpLayout>
