---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for English (no prefix in id)
  const enEntries = helpEntries.filter(entry => !entry.id.includes('/'));
  return enEntries.map(entry => ({
    params: { slug: entry.id },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === slug);

if (!entry) {
  return Astro.redirect('/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="en">
  <Content />
</HelpLayout>
