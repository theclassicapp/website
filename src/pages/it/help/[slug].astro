---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for it locale (entries with it/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('it/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('it/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'it/' + slug);

if (!entry) {
  return Astro.redirect('/it/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="it">
  <Content />
</HelpLayout>
