---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for ja locale (entries with ja/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('ja/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('ja/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'ja/' + slug);

if (!entry) {
  return Astro.redirect('/ja/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="ja">
  <Content />
</HelpLayout>
