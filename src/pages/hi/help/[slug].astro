---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for hi locale (entries with hi/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('hi/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('hi/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'hi/' + slug);

if (!entry) {
  return Astro.redirect('/hi/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="hi">
  <Content />
</HelpLayout>
