---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for es locale (entries with es/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('es/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('es/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'es/' + slug);

if (!entry) {
  return Astro.redirect('/es/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="es">
  <Content />
</HelpLayout>
