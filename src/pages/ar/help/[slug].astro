---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for ar locale (entries with ar/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('ar/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('ar/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'ar/' + slug);

if (!entry) {
  return Astro.redirect('/ar/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="ar">
  <Content />
</HelpLayout>
