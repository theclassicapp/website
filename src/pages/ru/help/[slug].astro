---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for ru locale (entries with ru/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('ru/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('ru/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'ru/' + slug);

if (!entry) {
  return Astro.redirect('/ru/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="ru">
  <Content />
</HelpLayout>
