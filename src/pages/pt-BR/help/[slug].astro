---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  const localeEntries = helpEntries.filter(entry => entry.slug.startsWith('pt-BR/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.slug.replace('pt-BR/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.slug === `pt-BR/${slug}`);

if (!entry) {
  return Astro.redirect('/pt-BR/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="pt-BR">
  <Content />
</HelpLayout>
