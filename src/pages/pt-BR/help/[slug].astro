---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for pt-BR locale (entries with pt-BR/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('pt-BR/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('pt-BR/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'pt-BR/' + slug);

if (!entry) {
  return Astro.redirect('/pt-BR/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="pt-BR">
  <Content />
</HelpLayout>
