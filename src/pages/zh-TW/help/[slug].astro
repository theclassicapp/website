---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for zh-TW locale (entries with zh-TW/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('zh-TW/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('zh-TW/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'zh-TW/' + slug);

if (!entry) {
  return Astro.redirect('/zh-TW/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="zh-TW">
  <Content />
</HelpLayout>
