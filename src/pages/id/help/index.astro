---
import '@/styles/global.css';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { withBase } from '@/i18n';

const base = import.meta.env.BASE_URL;

const helpCategories = [
  {
    title: 'Memulai',
    description: 'Pelajari dasar-dasar Classic dan mulai dengan cepat.',
    articles: [
      { slug: 'getting-started', title: 'Panduan Memulai Cepat' },
      { slug: 'interface', title: 'Memahami Antarmuka' },
      { slug: 'first-note', title: 'Membuat Catatan Pertama' },
    ],
  },
  {
    title: 'Editor & Penulisan',
    description: 'Kuasai editor yang powerful dan semua fiturnya.',
    articles: [
      { slug: 'markdown', title: 'Referensi Markdown' },
      { slug: 'slash-commands', title: 'Slash Commands' },
      { slug: 'diagrams', title: 'Diagram Mermaid' },
      { slug: 'math', title: 'Persamaan Matematika' },
      { slug: 'code-blocks', title: 'Blok Kode' },
    ],
  },
  {
    title: 'Organisasi',
    description: 'Atur catatan Anda dengan tag, subnote, dan backlink.',
    articles: [
      { slug: 'subnotes', title: 'Subnote' },
      { slug: 'tags', title: 'Bekerja dengan Tag' },
      { slug: 'backlinks', title: 'Backlink' },
      { slug: 'daily-notes', title: 'Catatan Harian' },
      { slug: 'search', title: 'Pencarian' },
    ],
  },
  {
    title: 'Produktivitas',
    description: 'Tingkatkan produktivitas Anda dengan shortcut dan otomatisasi.',
    articles: [
      { slug: 'quick-capture', title: 'Quick Capture' },
      { slug: 'command-palette', title: 'Command Palette' },
      { slug: 'keyboard-shortcuts', title: 'Shortcut Keyboard' },
      { slug: 'system-tray', title: 'System Tray' },
    ],
  },
  {
    title: 'Data & Privasi',
    description: 'Pahami bagaimana Classic menangani data Anda.',
    articles: [
      { slug: 'local-first', title: 'Arsitektur Local-First' },
      { slug: 'backup', title: 'Backup & Restore' },
      { slug: 'version-history', title: 'Riwayat Versi' },
      { slug: 'import-export', title: 'Impor & Ekspor' },
    ],
  },
  {
    title: 'Kustomisasi',
    description: 'Sesuaikan Classic dengan workflow Anda.',
    articles: [
      { slug: 'themes', title: 'Tema & Tampilan' },
      { slug: 'languages', title: 'Pengaturan Bahasa' },
      { slug: 'settings', title: 'Ikhtisar Pengaturan' },
    ],
  },
];
---

<BaseLayout title="Pusat Bantuan — Classic">
  <Header />
  <main>
    <section class="py-24 text-center">
      <div class="mx-auto max-w-6xl px-6">
        <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Pusat Bantuan
        </h1>
        <p class="mt-4 text-lg text-foreground-muted">
          Semua yang perlu Anda ketahui tentang Classic. Temukan panduan, tutorial, dan jawaban untuk pertanyaan umum.
        </p>
      </div>
    </section>

    <section class="bg-surface-dim py-16">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {helpCategories.map((category) => (
            <div class="rounded-xl border border-border bg-surface p-6">
              <h3 class="text-lg font-semibold text-foreground">
                {category.title}
              </h3>
              <p class="mt-2 text-sm text-foreground-muted">
                {category.description}
              </p>
              <ul class="mt-4 space-y-2">
                {category.articles.map((article) => (
                  <li>
                    <a
                      href={withBase(base, `/id/help/${article.slug}`)}
                      class="flex items-center gap-2 text-sm text-primary hover:underline"
                    >
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      {article.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold text-foreground">Artikel Populer</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <a href={withBase(base, '/id/help/getting-started')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Panduan Memulai Cepat</h3>
            <p class="mt-1 text-sm text-foreground-muted">Mulai dengan Classic dalam 5 menit.</p>
          </a>
          <a href={withBase(base, '/id/help/markdown')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Referensi Markdown</h3>
            <p class="mt-1 text-sm text-foreground-muted">Panduan lengkap sintaks Markdown.</p>
          </a>
          <a href={withBase(base, '/id/help/keyboard-shortcuts')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Shortcut Keyboard</h3>
            <p class="mt-1 text-sm text-foreground-muted">Bekerja lebih cepat dengan shortcut keyboard.</p>
          </a>
          <a href={withBase(base, '/id/help/local-first')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Arsitektur Local-First</h3>
            <p class="mt-1 text-sm text-foreground-muted">Bagaimana Classic menjaga privasi data Anda.</p>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
