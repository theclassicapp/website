---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for id locale (entries with id/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('id/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('id/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'id/' + slug);

if (!entry) {
  return Astro.redirect('/id/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="id">
  <Content />
</HelpLayout>
