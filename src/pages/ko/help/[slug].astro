---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for ko locale (entries with ko/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('ko/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('ko/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'ko/' + slug);

if (!entry) {
  return Astro.redirect('/ko/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="ko">
  <Content />
</HelpLayout>
