---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for zh-CN locale (entries with zh-CN/ prefix)
  const zhCNEntries = helpEntries.filter(entry => entry.slug.startsWith('zh-CN/'));
  return zhCNEntries.map(entry => ({
    params: { slug: entry.slug.replace('zh-CN/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.slug === `zh-CN/${slug}`);

if (!entry) {
  return Astro.redirect('/zh-CN/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="zh-CN">
  <Content />
</HelpLayout>
