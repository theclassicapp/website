---
import '@/styles/global.css';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { withBase } from '@/i18n';

const base = import.meta.env.BASE_URL;

const helpCategories = [
  {
    title: 'Başlarken',
    description: 'Classic\'in temellerini öğrenin ve hızla başlayın.',
    articles: [
      { slug: 'getting-started', title: 'Hızlı Başlangıç Kılavuzu' },
      { slug: 'interface', title: 'Arayüzü Anlamak' },
      { slug: 'first-note', title: 'İlk Notunuzu Oluşturun' },
    ],
  },
  {
    title: 'Düzenleyici ve Yazma',
    description: 'Güçlü düzenleyiciyi ve tüm özelliklerini öğrenin.',
    articles: [
      { slug: 'markdown', title: 'Markdown Referansı' },
      { slug: 'slash-commands', title: 'Slash Komutları' },
      { slug: 'diagrams', title: 'Mermaid Diyagramları' },
      { slug: 'math', title: 'Matematik Denklemleri' },
      { slug: 'code-blocks', title: 'Kod Blokları' },
    ],
  },
  {
    title: 'Organizasyon',
    description: 'Notlarınızı etiketler, alt notlar ve geri bağlantılarla düzenleyin.',
    articles: [
      { slug: 'subnotes', title: 'Alt Notlar' },
      { slug: 'tags', title: 'Etiketlerle Çalışma' },
      { slug: 'backlinks', title: 'Geri Bağlantılar' },
      { slug: 'daily-notes', title: 'Günlük Notlar' },
      { slug: 'search', title: 'Arama' },
    ],
  },
  {
    title: 'Verimlilik',
    description: 'Kısayollar ve otomasyon ile verimliliğinizi artırın.',
    articles: [
      { slug: 'quick-capture', title: 'Hızlı Yakalama' },
      { slug: 'command-palette', title: 'Komut Paleti' },
      { slug: 'keyboard-shortcuts', title: 'Klavye Kısayolları' },
      { slug: 'system-tray', title: 'Sistem Tepsisi' },
    ],
  },
  {
    title: 'Veri ve Gizlilik',
    description: 'Classic\'in verilerinizi nasıl işlediğini anlayın.',
    articles: [
      { slug: 'local-first', title: 'Local-First Mimarisi' },
      { slug: 'backup', title: 'Yedekleme ve Geri Yükleme' },
      { slug: 'version-history', title: 'Sürüm Geçmişi' },
      { slug: 'import-export', title: 'İçe ve Dışa Aktarma' },
    ],
  },
  {
    title: 'Özelleştirme',
    description: 'Classic\'i iş akışınıza göre özelleştirin.',
    articles: [
      { slug: 'themes', title: 'Temalar ve Görünüm' },
      { slug: 'languages', title: 'Dil Ayarları' },
      { slug: 'settings', title: 'Ayarlar Genel Bakış' },
    ],
  },
];
---

<BaseLayout title="Yardım Merkezi — Classic">
  <Header />
  <main>
    <section class="py-24 text-center">
      <div class="mx-auto max-w-6xl px-6">
        <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Yardım Merkezi
        </h1>
        <p class="mt-4 text-lg text-foreground-muted">
          Classic hakkında bilmeniz gereken her şey. Kılavuzları, eğitimleri ve sık sorulan soruların cevaplarını bulun.
        </p>
      </div>
    </section>

    <section class="bg-surface-dim py-16">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {helpCategories.map((category) => (
            <div class="rounded-xl border border-border bg-surface p-6">
              <h3 class="text-lg font-semibold text-foreground">
                {category.title}
              </h3>
              <p class="mt-2 text-sm text-foreground-muted">
                {category.description}
              </p>
              <ul class="mt-4 space-y-2">
                {category.articles.map((article) => (
                  <li>
                    <a
                      href={withBase(base, `/tr/help/${article.slug}`)}
                      class="flex items-center gap-2 text-sm text-primary hover:underline"
                    >
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      {article.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold text-foreground">Popüler Makaleler</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <a href={withBase(base, '/tr/help/getting-started')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Hızlı Başlangıç Kılavuzu</h3>
            <p class="mt-1 text-sm text-foreground-muted">5 dakikada Classic\'e başlayın.</p>
          </a>
          <a href={withBase(base, '/tr/help/markdown')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Markdown Referansı</h3>
            <p class="mt-1 text-sm text-foreground-muted">Markdown sözdizimi için tam kılavuz.</p>
          </a>
          <a href={withBase(base, '/tr/help/keyboard-shortcuts')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Klavye Kısayolları</h3>
            <p class="mt-1 text-sm text-foreground-muted">Klavye kısayollarıyla daha hızlı çalışın.</p>
          </a>
          <a href={withBase(base, '/tr/help/local-first')} class="rounded-lg border border-border bg-surface p-4 transition-colors hover:border-primary">
            <h3 class="font-medium text-foreground">Local-First Mimarisi</h3>
            <p class="mt-1 text-sm text-foreground-muted">Classic veri gizliliğinizi nasıl korur.</p>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
