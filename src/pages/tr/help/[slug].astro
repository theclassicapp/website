---
import { getCollection, render } from 'astro:content';
import HelpLayout from '@/components/help/HelpLayout.astro';

export async function getStaticPaths() {
  const helpEntries = await getCollection('help');
  // Filter for tr locale (entries with tr/ prefix in id)
  const localeEntries = helpEntries.filter(entry => entry.id.startsWith('tr/'));
  return localeEntries.map(entry => ({
    params: { slug: entry.id.replace('tr/', '') },
  }));
}

const slug = Astro.params.slug as string;
const entry = (await getCollection('help')).find(e => e.id === 'tr/' + slug);

if (!entry) {
  return Astro.redirect('/tr/help');
}

const { Content } = await render(entry);
---

<HelpLayout currentSlug={slug} locale="tr">
  <Content />
</HelpLayout>
