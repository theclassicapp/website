---
import { t, getLocale, getLocalePath } from '@/i18n';
import LanguageSwitcher from '@/components/shared/LanguageSwitcher.astro';
import ThemeToggle from '@/components/shared/ThemeToggle.astro';

const locale = getLocale(Astro.currentLocale);
const base = import.meta.env.BASE_URL;

const navLinks = [
  { href: getLocalePath(locale, '/features'), label: t(locale, 'nav.features') },
  { href: getLocalePath(locale, '/download'), label: t(locale, 'nav.download') },
  { href: getLocalePath(locale, '/pricing'), label: t(locale, 'nav.pricing') },
];
---

<header class="sticky top-0 z-50 border-b border-border bg-surface/80 backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <!-- Logo -->
    <a href={`${base}${getLocalePath(locale, '/')}`} class="flex items-center gap-2 text-lg font-semibold text-foreground no-underline">
      <span class="font-heading text-xl">Classic</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-8 md:flex">
      {navLinks.map(link => (
        <a href={`${base}${link.href}`} class="text-sm text-foreground-muted transition-colors hover:text-foreground">
          {link.label}
        </a>
      ))}
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <ThemeToggle />
      <LanguageSwitcher />
      <a
        href="https://github.com/theclassicapp/classic"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden text-sm text-foreground-muted transition-colors hover:text-foreground sm:inline-flex"
        aria-label="GitHub"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="inline-flex items-center justify-center rounded-md p-2 text-foreground-muted hover:text-foreground md:hidden"
        aria-label="Toggle menu"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <div class="space-y-1 px-6 py-4">
      {navLinks.map(link => (
        <a href={`${base}${link.href}`} class="block py-2 text-sm text-foreground-muted transition-colors hover:text-foreground">
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/theclassicapp/classic"
        target="_blank"
        rel="noopener noreferrer"
        class="block py-2 text-sm text-foreground-muted transition-colors hover:text-foreground"
      >
        GitHub
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
