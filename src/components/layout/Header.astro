---
import { t, getLocale, getLocalePath } from '@/i18n';
import LanguageSwitcher from '@/components/shared/LanguageSwitcher.astro';
import ThemeToggle from '@/components/shared/ThemeToggle.astro';

const locale = getLocale(Astro.currentLocale);
const base = import.meta.env.BASE_URL;
const normalizedBase = base === '/' ? '' : base;

const navLinks = [
  { href: getLocalePath(locale, '/features'), label: t(locale, 'nav.features') },
  { href: getLocalePath(locale, '/download'), label: t(locale, 'nav.download') },
  { href: getLocalePath(locale, '/pricing'), label: t(locale, 'nav.pricing') },
];
---

<header class="sticky top-0 z-50 border-b border-border bg-surface/80 backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <!-- Logo -->
    <a href={`${normalizedBase}${getLocalePath(locale, '/')}`} class="flex items-center gap-2 text-lg font-semibold text-foreground no-underline">
      <span class="font-heading text-xl">Classic</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-8 md:flex">
      {navLinks.map(link => (
        <a href={`${normalizedBase}${link.href}`} class="text-sm text-foreground-muted transition-colors hover:text-foreground">
          {link.label}
        </a>
      ))}
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <ThemeToggle />
      <LanguageSwitcher />

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="inline-flex items-center justify-center rounded-md p-2 text-foreground-muted hover:text-foreground md:hidden"
        aria-label="Toggle menu"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <div class="space-y-1 px-6 py-4">
      {navLinks.map(link => (
        <a href={`${normalizedBase}${link.href}`} class="block py-2 text-sm text-foreground-muted transition-colors hover:text-foreground">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
