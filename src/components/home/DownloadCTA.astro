---
import { t, getLocale, getLocalePath, withBase } from '@/i18n';
import Button from '@/components/shared/Button.astro';

const locale = getLocale(Astro.currentLocale);
const base = import.meta.env.BASE_URL;
---

<section class="py-24">
  <div class="mx-auto max-w-6xl px-6 text-center">
    <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
      {t(locale, 'cta.title')}
    </h2>
    <p class="mt-4 text-lg text-foreground-muted">
      {t(locale, 'cta.subtitle')}
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <Button href={withBase(base, getLocalePath(locale, '/download'))} variant="primary" size="lg">
        {t(locale, 'cta.button')}
      </Button>
    </div>
    <!-- Platform icons -->
    <div class="mt-8 flex items-center justify-center gap-6 text-foreground-muted">
      <!-- macOS -->
      <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
      <!-- Windows -->
      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>
      </svg>
      <!-- Linux -->
      <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.368 1.884 1.43.868.07 1.726-.283 2.275-.917.547-.636.802-1.524.804-2.469.017-.468-.043-.94-.164-1.404-.419-1.332-.89-1.643-1.267-1.809-.12-.065-.263-.084-.413-.13l-.006-.009c-.211-.352-.422-.69-.63-.998-.039-.049-.078-.1-.122-.149-.473-.538-.923-1.06-1.273-1.688-.128-.23-.226-.465-.29-.694-.122-.441-.107-.885-.141-1.341-.03-.397-.044-.885-.135-1.413-.132-1.602-.762-2.942-1.665-3.986-.655-.72-1.456-1.3-2.361-1.69-.24-.104-.416-.171-.65-.265-.123-.055-.27-.093-.393-.132A6.2 6.2 0 0012.504 0z"/>
      </svg>
    </div>
  </div>
</section>
