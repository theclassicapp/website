---
import { t, getLocale } from '@/i18n';

const locale = getLocale(Astro.currentLocale);

const highlights = [
  { key: 'capture', icon: 'rocket' },
  { key: 'local', icon: 'lock' },
  { key: 'cross', icon: 'globe' },
  { key: 'zero', icon: 'sparkle' },
];
---

<section class="bg-surface-dim py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        {t(locale, 'features.highlights.title')}
      </h2>
      <p class="mt-4 text-lg text-foreground-muted">
        {t(locale, 'features.highlights.subtitle')}
      </p>
    </div>

    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {highlights.map(({ key, icon }) => (
        <div class="text-center">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
            {icon === 'rocket' && (
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            )}
            {icon === 'lock' && (
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            )}
            {icon === 'globe' && (
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {icon === 'sparkle' && (
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
            )}
          </div>
          <h3 class="mt-4 text-lg font-semibold text-foreground">
            {t(locale, `features.highlight.${key}.title`)}
          </h3>
          <p class="mt-2 text-sm text-foreground-muted">
            {t(locale, `features.highlight.${key}.desc`)}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
