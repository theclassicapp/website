---
import { t, getLocale } from '@/i18n';

const locale = getLocale(Astro.currentLocale);

const features = ['markdown', 'slash', 'mermaid', 'katex', 'code'];
---

<section class="py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Text -->
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          {t(locale, 'editor.title')}
        </h2>
        <p class="mt-4 text-lg text-foreground-muted">
          {t(locale, 'editor.subtitle')}
        </p>
        <ul class="mt-8 space-y-4">
          {features.map(key => (
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-foreground-muted">{t(locale, `editor.feature.${key}`)}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Editor mockup -->
      <div class="overflow-hidden rounded-xl border border-border bg-surface-dim shadow-lg">
        <div class="flex items-center gap-2 border-b border-border px-4 py-3">
          <div class="h-3 w-3 rounded-full bg-red-400"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-400"></div>
          <div class="h-3 w-3 rounded-full bg-green-400"></div>
          <span class="ml-2 text-xs text-foreground-muted">notes.md</span>
        </div>
        <div class="p-6 font-mono text-sm leading-relaxed text-foreground-muted">
          <p class="text-foreground"><span class="text-accent">#</span> Welcome to Classic</p>
          <p class="mt-3">A **beautiful** note-taking app that puts</p>
          <p>your _privacy_ first.</p>
          <p class="mt-3 text-foreground-muted/60">---</p>
          <p class="mt-3"><span class="text-accent">##</span> <span class="text-foreground">Features</span></p>
          <p class="mt-2">- [x] Markdown support</p>
          <p>- [x] Local-first storage</p>
          <p>- [ ] Cloud sync <span class="text-foreground-muted/40">(coming soon)</span></p>
          <p class="mt-3"><span class="text-accent">></span> Less is more. — <em>Classic</em></p>
        </div>
      </div>
    </div>
  </div>
</section>
