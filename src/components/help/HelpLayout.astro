---
import '@/styles/global.css';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { withBase } from '@/i18n';

const base = import.meta.env.BASE_URL;
const { currentSlug, locale = 'en' } = Astro.props;

// Helper to get help path (always links to English docs since translations not available)
function getHelpPath(slug: string): string {
  return withBase(base, `/help/${slug}`);
}

function getHelpIndexPath(): string {
  if (locale === 'en') {
    return withBase(base, '/help');
  }
  return withBase(base, `/${locale}/help`);
}

// UI Text translations
const uiText: Record<string, { backToHelp: string; previous: string; next: string }> = {
  en: { backToHelp: 'Back to Help Center', previous: 'Previous', next: 'Next' },
  'zh-CN': { backToHelp: '返回帮助中心', previous: '上一篇', next: '下一篇' },
  'zh-TW': { backToHelp: '返回說明中心', previous: '上一篇', next: '下一篇' },
  ja: { backToHelp: 'ヘルプセンターに戻る', previous: '前へ', next: '次へ' },
  ko: { backToHelp: '도움말 센터로 돌아가기', previous: '이전', next: '다음' },
  de: { backToHelp: 'Zurück zum Hilfezentrum', previous: 'Vorherige', next: 'Nächste' },
  es: { backToHelp: 'Volver al Centro de Ayuda', previous: 'Anterior', next: 'Siguiente' },
  fr: { backToHelp: "Retour au Centre d'Aide", previous: 'Précédent', next: 'Suivant' },
  it: { backToHelp: 'Torna al Centro Assistenza', previous: 'Precedente', next: 'Successivo' },
  pt: { backToHelp: 'Voltar ao Centro de Ajuda', previous: 'Anterior', next: 'Próximo' },
  ru: { backToHelp: 'Вернуться в Справочный центр', previous: 'Назад', next: 'Далее' },
  ar: { backToHelp: 'العودة إلى مركز المساعدة', previous: 'السابق', next: 'التالي' },
  he: { backToHelp: 'חזרה למרכז העזרה', previous: 'הקודם', next: 'הבא' },
  hi: { backToHelp: 'सहायता केंद्र पर वापस जाएं', previous: 'पिछला', next: 'अगला' },
  id: { backToHelp: 'Kembali ke Pusat Bantuan', previous: 'Sebelumnya', next: 'Selanjutnya' },
  nl: { backToHelp: 'Terug naar Helpcentrum', previous: 'Vorige', next: 'Volgende' },
  pl: { backToHelp: 'Powrót do Centrum Pomocy', previous: 'Poprzedni', next: 'Następny' },
  th: { backToHelp: 'กลับไปยังศูนย์ช่วยเหลือ', previous: 'ก่อนหน้า', next: 'ถัดไป' },
  tr: { backToHelp: 'Yardım Merkezine Dön', previous: 'Önceki', next: 'Sonraki' },
  vi: { backToHelp: 'Quay lại Trung tâm Trợ giúp', previous: 'Trước', next: 'Tiếp' },
};

const t = uiText[locale] || uiText['en'];

// Navigation for help articles
const allArticles = [
  { slug: 'getting-started', title: 'Quick Start Guide', category: 'Getting Started' },
  { slug: 'interface', title: 'Understanding the Interface', category: 'Getting Started' },
  { slug: 'first-note', title: 'Creating Your First Note', category: 'Getting Started' },
  { slug: 'markdown', title: 'Markdown Reference', category: 'Editor & Writing' },
  { slug: 'slash-commands', title: 'Slash Commands', category: 'Editor & Writing' },
  { slug: 'diagrams', title: 'Mermaid Diagrams', category: 'Editor & Writing' },
  { slug: 'math', title: 'Math Equations with KaTeX', category: 'Editor & Writing' },
  { slug: 'code-blocks', title: 'Code Blocks & Syntax Highlighting', category: 'Editor & Writing' },
  { slug: 'subnotes', title: 'Sub-notes & Hierarchies', category: 'Organization' },
  { slug: 'tags', title: 'Working with Tags', category: 'Organization' },
  { slug: 'backlinks', title: 'Backlinks & Connections', category: 'Organization' },
  { slug: 'daily-notes', title: 'Daily Notes', category: 'Organization' },
  { slug: 'search', title: 'Search & Find', category: 'Organization' },
  { slug: 'quick-capture', title: 'Quick Capture', category: 'Productivity' },
  { slug: 'command-palette', title: 'Command Palette', category: 'Productivity' },
  { slug: 'keyboard-shortcuts', title: 'Keyboard Shortcuts', category: 'Productivity' },
  { slug: 'system-tray', title: 'System Tray', category: 'Productivity' },
  { slug: 'local-first', title: 'Local-First Architecture', category: 'Data & Privacy' },
  { slug: 'backup', title: 'Backup & Restore', category: 'Data & Privacy' },
  { slug: 'version-history', title: 'Version History', category: 'Data & Privacy' },
  { slug: 'import-export', title: 'Import & Export', category: 'Data & Privacy' },
  { slug: 'themes', title: 'Themes & Appearance', category: 'Customization' },
  { slug: 'languages', title: 'Language Settings', category: 'Customization' },
  { slug: 'settings', title: 'Settings Overview', category: 'Customization' },
];

// Group articles by category
const categories = [
  { name: 'Getting Started', articles: allArticles.filter(a => a.category === 'Getting Started') },
  { name: 'Editor & Writing', articles: allArticles.filter(a => a.category === 'Editor & Writing') },
  { name: 'Organization', articles: allArticles.filter(a => a.category === 'Organization') },
  { name: 'Productivity', articles: allArticles.filter(a => a.category === 'Productivity') },
  { name: 'Data & Privacy', articles: allArticles.filter(a => a.category === 'Data & Privacy') },
  { name: 'Customization', articles: allArticles.filter(a => a.category === 'Customization') },
];

// Find current article index
const currentIndex = allArticles.findIndex(a => a.slug === currentSlug);
const prevArticle = currentIndex > 0 ? allArticles[currentIndex - 1] : null;
const nextArticle = currentIndex < allArticles.length - 1 ? allArticles[currentIndex + 1] : null;

// Get current article info
const currentArticle = allArticles.find(a => a.slug === currentSlug);
const title = currentArticle?.title || 'Help';
const category = currentArticle?.category || 'Help';
const description = '';
---

<BaseLayout title={`${title} — Classic Help`}>
  <Header />
  <main class="min-h-screen bg-surface-dim">
    <div class="mx-auto max-w-7xl px-4 py-8 lg:px-8">
      <div class="lg:grid lg:grid-cols-[280px_1fr] lg:gap-12">
        <!-- Sidebar Navigation -->
        <aside class="hidden lg:block">
          <nav class="sticky top-8 space-y-6">
            <!-- Back to Help Center -->
            <a
              href={getHelpIndexPath()}
              class="flex items-center gap-2 text-sm font-medium text-foreground-muted transition-colors hover:text-foreground"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              {t.backToHelp}
            </a>

            <!-- Category Navigation -->
            {categories.map((cat) => (
              <div class="space-y-2">
                <h3 class="px-3 text-xs font-semibold uppercase tracking-wider text-foreground-muted">
                  {cat.name}
                </h3>
                <ul class="space-y-1">
                  {cat.articles.map((article) => {
                    const isActive = article.slug === currentSlug;
                    return (
                      <li>
                        <a
                          href={getHelpPath(article.slug)}
                          class:list={[
                            'block rounded-lg px-3 py-2 text-sm transition-all duration-200',
                            isActive
                              ? 'bg-primary/10 font-medium text-primary'
                              : 'text-foreground-muted hover:bg-surface hover:text-foreground'
                          ]}
                        >
                          {article.title}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))}
          </nav>
        </aside>

        <!-- Main Content -->
        <div class="min-w-0">
          <!-- Breadcrumb -->
          <nav class="mb-6 flex items-center gap-2 text-sm">
            <a href={getHelpIndexPath()} class="text-foreground-muted hover:text-foreground">
              Help
            </a>
            <svg class="h-4 w-4 text-foreground-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            <span class="font-medium text-foreground">{title}</span>
          </nav>

          <!-- Article -->
          <article class="rounded-2xl border border-border bg-surface p-8 shadow-sm lg:p-12">
            <!-- Article Header -->
            <header class="mb-8 border-b border-border pb-8">
              <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
                {category}
              </span>
              <h1 class="mt-4 text-3xl font-bold tracking-tight text-foreground lg:text-4xl">
                {title}
              </h1>
              {description && (
                <p class="mt-4 text-lg text-foreground-muted">
                  {description}
                </p>
              )}
            </header>

            <!-- Article Content -->
            <div class="help-content">
              <slot />
            </div>
          </article>

          <!-- Navigation -->
          <nav class="mt-8 flex items-center justify-between gap-4 border-t border-border pt-8">
            {prevArticle ? (
              <a
                href={getHelpPath(prevArticle.slug)}
                class="group flex flex-1 items-center gap-3 rounded-xl border border-border bg-surface p-4 transition-all hover:border-primary hover:shadow-md"
              >
                <svg class="h-5 w-5 text-foreground-muted transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                <div class="text-left">
                  <span class="block text-xs text-foreground-muted">{t.previous}</span>
                  <span class="font-medium text-foreground">{prevArticle.title}</span>
                </div>
              </a>
            ) : (
              <div class="flex-1"></div>
            )}

            {nextArticle ? (
              <a
                href={getHelpPath(nextArticle.slug)}
                class="group flex flex-1 items-center justify-end gap-3 rounded-xl border border-border bg-surface p-4 text-right transition-all hover:border-primary hover:shadow-md"
              >
                <div>
                  <span class="block text-xs text-foreground-muted">{t.next}</span>
                  <span class="font-medium text-foreground">{nextArticle.title}</span>
                </div>
                <svg class="h-5 w-5 text-foreground-muted transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ) : (
              <div class="flex-1"></div>
            )}
          </nav>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Hide first h1 in content since we show it in the header */
  .help-content :global(h1:first-child) {
    display: none;
  }

  /* Help content styling */
  .help-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-foreground);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.5rem;
  }

  .help-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .help-content :global(h4) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .help-content :global(p) {
    margin-bottom: 1rem;
    line-height: 1.75;
    color: var(--color-foreground-muted);
  }

  .help-content :global(ul),
  .help-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    color: var(--color-foreground-muted);
  }

  .help-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }

  .help-content :global(a) {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .help-content :global(a:hover) {
    text-decoration: underline;
  }

  .help-content :global(code) {
    background-color: var(--color-surface-dim);
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
    padding: 0.125rem 0.375rem;
    font-size: 0.875em;
    font-family: ui-monospace, monospace;
    color: var(--color-primary);
  }

  .help-content :global(pre) {
    margin-bottom: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface-dim);
    padding: 1rem;
    overflow-x: auto;
  }

  .help-content :global(pre code) {
    background-color: transparent;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    color: var(--color-foreground);
  }

  .help-content :global(blockquote) {
    margin: 1.5rem 0;
    border-left: 4px solid var(--color-primary);
    padding-left: 1.25rem;
    font-style: italic;
    color: var(--color-foreground-muted);
  }

  .help-content :global(table) {
    margin-bottom: 1.5rem;
    width: 100%;
    border-collapse: collapse;
  }

  .help-content :global(th),
  .help-content :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
    text-align: left;
  }

  .help-content :global(th) {
    background-color: var(--color-surface-dim);
    font-weight: 600;
    color: var(--color-foreground);
  }

  .help-content :global(td) {
    color: var(--color-foreground-muted);
  }

  .help-content :global(hr) {
    margin: 2.5rem 0;
    border-color: var(--color-border);
  }

  .help-content :global(kbd) {
    display: inline-flex;
    align-items: center;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface-dim);
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    font-family: ui-monospace, monospace;
    color: var(--color-foreground-muted);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }

  .help-content :global(img) {
    margin-bottom: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
  }

  .help-content :global(strong) {
    font-weight: 600;
    color: var(--color-foreground);
  }
</style>
