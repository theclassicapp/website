---
import '@/styles/global.css';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { withBase } from '@/i18n';

const base = import.meta.env.BASE_URL;
const { title, description, category } = Astro.props;

// Navigation for help articles
const allArticles = [
  { slug: 'getting-started', title: 'Quick Start Guide', category: 'Getting Started' },
  { slug: 'interface', title: 'Understanding the Interface', category: 'Getting Started' },
  { slug: 'first-note', title: 'Creating Your First Note', category: 'Getting Started' },
  { slug: 'markdown', title: 'Markdown Reference', category: 'Editor & Writing' },
  { slug: 'slash-commands', title: 'Slash Commands', category: 'Editor & Writing' },
  { slug: 'diagrams', title: 'Mermaid Diagrams', category: 'Editor & Writing' },
  { slug: 'math', title: 'Math Equations with KaTeX', category: 'Editor & Writing' },
  { slug: 'code-blocks', title: 'Code Blocks & Syntax Highlighting', category: 'Editor & Writing' },
  { slug: 'subnotes', title: 'Sub-notes & Hierarchies', category: 'Organization' },
  { slug: 'tags', title: 'Working with Tags', category: 'Organization' },
  { slug: 'backlinks', title: 'Backlinks & Connections', category: 'Organization' },
  { slug: 'daily-notes', title: 'Daily Notes', category: 'Organization' },
  { slug: 'search', title: 'Search & Find', category: 'Organization' },
  { slug: 'quick-capture', title: 'Quick Capture', category: 'Productivity' },
  { slug: 'command-palette', title: 'Command Palette', category: 'Productivity' },
  { slug: 'keyboard-shortcuts', title: 'Keyboard Shortcuts', category: 'Productivity' },
  { slug: 'system-tray', title: 'System Tray', category: 'Productivity' },
  { slug: 'local-first', title: 'Local-First Architecture', category: 'Data & Privacy' },
  { slug: 'backup', title: 'Backup & Restore', category: 'Data & Privacy' },
  { slug: 'version-history', title: 'Version History', category: 'Data & Privacy' },
  { slug: 'import-export', title: 'Import & Export', category: 'Data & Privacy' },
  { slug: 'themes', title: 'Themes & Appearance', category: 'Customization' },
  { slug: 'languages', title: 'Language Settings', category: 'Customization' },
  { slug: 'settings', title: 'Settings Overview', category: 'Customization' },
];

// Find current article index
const currentIndex = allArticles.findIndex(a => a.title === title);
const prevArticle = currentIndex > 0 ? allArticles[currentIndex - 1] : null;
const nextArticle = currentIndex < allArticles.length - 1 ? allArticles[currentIndex + 1] : null;
---

<BaseLayout title={`${title} — Classic Help`}>
  <Header />
  <main class="py-12">
    <div class="mx-auto max-w-6xl px-6">
      <div class="lg:grid lg:grid-cols-[280px_1fr] lg:gap-12">
        <!-- Sidebar -->
        <aside class="hidden lg:block">
          <nav class="sticky top-24 space-y-8">
            <div>
              <a href={withBase(base, '/help')} class="flex items-center gap-2 text-sm text-foreground-muted hover:text-foreground">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Help Center
              </a>
            </div>

            <!-- Category Navigation -->
            {['Getting Started', 'Editor & Writing', 'Organization', 'Productivity', 'Data & Privacy', 'Customization'].map((cat) => (
              <div>
                <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-foreground-muted">
                  {cat}
                </h3>
                <ul class="space-y-1">
                  {allArticles.filter(a => a.category === cat).map((article) => (
                    <li>
                      <a
                        href={withBase(base, `/help/${article.slug}`)}
                        class:list={[
                          'block rounded-lg px-3 py-1.5 text-sm transition-colors',
                          article.title === title
                            ? 'bg-primary/10 font-medium text-primary'
                            : 'text-foreground-muted hover:bg-surface-dim hover:text-foreground',
                        ]}
                      >
                        {article.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </nav>
        </aside>

        <!-- Main Content -->
        <div class="min-w-0">
          <!-- Mobile Back Link -->
          <div class="mb-6 lg:hidden">
            <a href={withBase(base, '/help')} class="flex items-center gap-2 text-sm text-foreground-muted hover:text-foreground">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              Back to Help Center
            </a>
          </div>

          <!-- Breadcrumb -->
          <div class="mb-4 flex items-center gap-2 text-sm text-foreground-muted">
            <a href={withBase(base, '/help')} class="hover:text-foreground">Help</a>
            <span>/</span>
            <span>{category}</span>
          </div>

          <!-- Article Header -->
          <header class="mb-8">
            <h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
              {title}
            </h1>
            {description && (
              <p class="mt-4 text-lg text-foreground-muted">
                {description}
              </p>
            )}
          </header>

          <!-- Article Content -->
          <article class="prose prose-slate dark:prose-invert max-w-none">
            <slot />
          </article>

          <!-- Navigation -->
          <nav class="mt-12 flex items-center justify-between border-t border-border pt-8">
            {prevArticle ? (
              <a
                href={withBase(base, `/help/${prevArticle.slug}`)}
                class="flex items-center gap-2 text-foreground-muted hover:text-foreground"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                <div>
                  <div class="text-xs text-foreground-muted">Previous</div>
                  <div class="text-sm font-medium">{prevArticle.title}</div>
                </div>
              </a>
            ) : <div></div>}

            {nextArticle ? (
              <a
                href={withBase(base, `/help/${nextArticle.slug}`)}
                class="flex items-center gap-2 text-right text-foreground-muted hover:text-foreground"
              >
                <div>
                  <div class="text-xs text-foreground-muted">Next</div>
                  <div class="text-sm font-medium">{nextArticle.title}</div>
                </div>
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ) : <div></div>}
          </nav>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .prose h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-foreground);
  }
  .prose h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
  }
  .prose p {
    margin-bottom: 1rem;
    color: var(--color-foreground-muted);
    line-height: 1.75;
  }
  .prose ul, .prose ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    color: var(--color-foreground-muted);
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
  .prose code {
    border-radius: 0.25rem;
    background-color: var(--color-surface-dim);
    padding: 0.125rem 0.375rem;
    font-size: 0.875rem;
    font-family: ui-monospace, monospace;
    color: var(--color-primary);
  }
  .prose pre {
    margin-bottom: 1rem;
    border-radius: 0.5rem;
    background-color: var(--color-surface-dim);
    padding: 1rem;
    overflow-x: auto;
  }
  .prose pre code {
    background-color: transparent;
    padding: 0;
  }
  .prose blockquote {
    border-left: 4px solid var(--color-primary);
    padding-left: 1rem;
    font-style: italic;
    color: var(--color-foreground-muted);
  }
  .prose a {
    color: var(--color-primary);
  }
  .prose a:hover {
    text-decoration: underline;
  }
  .prose table {
    margin-bottom: 1rem;
    width: 100%;
    border-collapse: collapse;
  }
  .prose th, .prose td {
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    text-align: left;
  }
  .prose th {
    background-color: var(--color-surface-dim);
    font-weight: 600;
    color: var(--color-foreground);
  }
  .prose img {
    margin-bottom: 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
  }
  .prose hr {
    margin: 2rem 0;
    border-color: var(--color-border);
  }
  .prose kbd {
    display: inline-flex;
    align-items: center;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface-dim);
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    font-family: ui-monospace, monospace;
    color: var(--color-foreground-muted);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }
</style>
