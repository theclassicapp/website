{
  "name": "classic-website",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "linkcheck": "lychee --root-dir dist --no-progress --max-concurrency 4 --retry-wait-time 10 --max-retries 3 --timeout 30 --accept 100..=103,200..=299,429 --exclude 'favicon.ico' --exclude '/404$' --exclude 'github.com/theclassicapp/classic/releases' --exclude 'theclassic.app/404' 'dist/**/*.html'"
  },
  "dependencies": {
    "astro": "^5.6.1",
    "@astrojs/sitemap": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.2"
  }
}
